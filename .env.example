# Plaid API Credentials
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox  # sandbox | development | production
PLAID_ACCESS_TOKEN=your_plaid_access_token

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=Sheet1

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Local DB
DB_PATH=./data/ledger.db
DB_ENCRYPTION_KEY=your_32_char_encryption_key_here_

# App Settings
CASH_ON_HAND=0.00
SAVINGS_GOAL_MONTHLY=0.00
ESSENTIAL_BUDGET_WEEKLY=0.00
