---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CodexSidebar from '../../../components/CodexSidebar.astro';
import { getCollection, render } from 'astro:content';
import { buildGraphIndex, getRelatedNodes } from '../../../lib/graph';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  const graph = await buildGraphIndex();

  return characters.map((entry) => ({
    params: { id: entry.id },
    props: {
      entry,
      relations: getRelatedNodes(graph, 'characters', entry.id),
    },
  }));
}

const { entry, relations } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.name}>
  <div class="codex-page">
    <div class="codex-main">
      <a href="/" class="back-link">&larr; Cosmos</a>
      <span class="entry-type">Character</span>
      <h1>{entry.data.name}</h1>
      {entry.data.title && <p class="title-line">{entry.data.title}</p>}
      <dl class="meta">
        <dt>Species</dt>
        <dd>{entry.data.species}</dd>
      </dl>
      <div class="content">
        <Content />
      </div>
    </div>
    <CodexSidebar relations={relations} />
  </div>
</BaseLayout>

<style>
  .codex-page {
    position: relative;
    z-index: 10;
    display: flex;
    gap: 32px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px 60px;
    min-height: 100vh;
    background: rgba(10, 10, 25, 0.95);
  }

  .codex-main { flex: 1; min-width: 0; }

  .back-link {
    font-family: monospace;
    font-size: 13px;
    color: rgba(200, 200, 255, 0.5);
    text-decoration: none;
  }

  .back-link:hover { color: #7B68EE; }

  .entry-type {
    display: inline-block;
    font-family: monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #7B68EE;
    background: rgba(123, 104, 238, 0.1);
    padding: 2px 8px;
    border-radius: 3px;
    margin-top: 12px;
  }

  h1 {
    font-family: monospace;
    font-size: 32px;
    color: rgba(230, 230, 250, 0.95);
    margin: 8px 0;
  }

  .title-line {
    font-style: italic;
    color: rgba(200, 200, 255, 0.6);
    margin-bottom: 16px;
  }

  .meta {
    display: flex;
    gap: 24px;
    font-family: monospace;
    font-size: 13px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(123, 104, 238, 0.15);
  }

  dt { color: rgba(200, 200, 255, 0.5); }
  dd { color: rgba(200, 200, 255, 0.8); margin: 0; }

  .content {
    color: rgba(220, 220, 240, 0.85);
    line-height: 1.8;
    font-size: 16px;
  }
</style>
