---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MapView from '../../components/MapView';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const planets = await getCollection('planets');
  return planets.map((planet) => ({
    params: { id: planet.id },
    props: { planet },
  }));
}

const { planet } = Astro.props;
const { Content } = await render(planet);

// Resolve region references for the map
const regions = await getCollection('regions');
const planetRegions = regions
  .filter((r) => r.data.planet.id === planet.id)
  .map((r) => ({
    id: r.id,
    name: r.data.name,
    x: r.data.mapPosition?.x ?? 200,
    y: r.data.mapPosition?.y ?? 200,
  }));
---

<BaseLayout title={planet.data.name}>
  <div class="planet-page">
    <header>
      <a href="/" class="back-link">&larr; Cosmos</a>
      <h1>{planet.data.name}</h1>
      <p class="description">{planet.data.description}</p>
    </header>

    <section class="map-section">
      <MapView
        client:load
        planetName={planet.data.name}
        regions={planetRegions}
      />
    </section>

    <section class="lore-content">
      <Content />
    </section>

    <section class="region-list">
      <h2>Regions</h2>
      <ul>
        {planetRegions.map((region) => (
          <li>
            <a href={`/codex/regions/${region.id}`}>{region.name}</a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .planet-page {
    position: relative;
    z-index: 10;
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 24px 60px;
    min-height: 100vh;
    background: rgba(10, 10, 25, 0.92);
  }

  .back-link {
    font-family: monospace;
    font-size: 13px;
    color: rgba(200, 200, 255, 0.5);
    text-decoration: none;
  }

  .back-link:hover { color: #7B68EE; }

  h1 {
    font-family: monospace;
    font-size: 36px;
    color: #7B68EE;
    margin: 8px 0;
  }

  .description {
    font-size: 16px;
    color: rgba(200, 200, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .map-section { margin-bottom: 40px; }

  .lore-content {
    color: rgba(220, 220, 240, 0.85);
    line-height: 1.8;
    font-size: 16px;
  }

  h2 {
    font-family: monospace;
    font-size: 20px;
    color: rgba(200, 200, 255, 0.8);
    margin-top: 40px;
  }

  .region-list ul {
    list-style: none;
    padding: 0;
  }

  .region-list li a {
    display: inline-block;
    padding: 6px 0;
    color: rgba(200, 200, 255, 0.7);
    text-decoration: none;
    font-size: 15px;
  }

  .region-list li a:hover { color: #7B68EE; }
</style>
