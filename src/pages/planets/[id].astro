---
import { getCollection, render } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import IdentityCard from '../../components/IdentityCard.astro';
import RegionAccordion from '../../components/RegionAccordion.astro';
import DiamondDivider from '../../components/DiamondDivider.astro';
import PaletteGrid from '../../components/PaletteGrid.astro';
import DesignPrinciples from '../../components/DesignPrinciples.astro';

export async function getStaticPaths() {
  const planets = await getCollection('planets');
  return planets.map((planet) => ({
    params: { id: planet.id },
    props: { planet },
  }));
}

const { planet } = Astro.props;
const { Content } = await render(planet);

// Resolve regions belonging to this planet
const allRegions = await getCollection('regions');
const regions = allRegions.filter((r) => r.data.planet.id === planet.id);

// Resolve patron deity and exvisar names for the identity card
const allCharacters = await getCollection('characters');
function resolveCharacterName(ref?: { id: string }) {
  if (!ref) return undefined;
  const char = allCharacters.find(c => c.id === ref.id);
  return char ? `<em>${char.data.name}</em> — ${char.data.title || char.data.description}` : ref.id;
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{planet.data.name} — Realm Codex | Crystata</title>
  <ClientRouter />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&display=swap" rel="stylesheet" />
  <style>
    @import '../../styles/realm.css';
  </style>
</head>
<body>

<div class="realm-page">
  <!-- Aether particles -->
  <div class="aether-particles" id="aetherParticles"></div>

  <!-- ===== HERO ===== -->
  <header class="realm-hero">
    <div class="realm-hero-tag">Crystata — Realm Codex</div>
    <h1 class="realm-hero-name">{planet.data.name}</h1>
    {planet.data.subtitle && (
      <div class="realm-hero-subtitle">{planet.data.subtitle}</div>
    )}
    {planet.data.epigraph && (
      <p class="realm-hero-epigraph">{planet.data.epigraph}</p>
    )}
    <div class="realm-hero-scroll">Descend<span>⌄</span></div>
  </header>

  <main class="realm-container">
    <!-- ===== IDENTITY CARD ===== -->
    <IdentityCard
      element={planet.data.element}
      patronDeity={resolveCharacterName(planet.data.patronDeity)}
      exvisar={resolveCharacterName(planet.data.exvisar)}
      population={planet.data.population}
      chromaticSignature={planet.data.chromaticSignature}
      materialHierarchy={planet.data.materialHierarchy}
      culturalAnalogs={planet.data.culturalAnalogs}
      narrativeFunction={planet.data.narrativeFunction}
    />

    <DiamondDivider />

    <!-- ===== BODY PROSE (The Land, The People, etc.) ===== -->
    <section class="realm-section reveal">
      <div class="realm-prose">
        <Content />
      </div>
    </section>

    <!-- ===== NATIONS & REGIONS ===== -->
    {regions.length > 0 && (
      <>
        <DiamondDivider />
        <section class="realm-section reveal">
          <h2 class="section-title">Nations & Regions</h2>
          <RegionAccordion regions={regions} />
        </section>
      </>
    )}

    <!-- ===== MATERIAL PALETTE ===== -->
    {planet.data.palette && planet.data.palette.length > 0 && (
      <>
        <DiamondDivider />
        <section class="realm-section reveal">
          <h2 class="section-title">Material Palette</h2>
          <PaletteGrid palette={planet.data.palette} />
        </section>
      </>
    )}

    <!-- ===== DESIGN PRINCIPLES ===== -->
    {planet.data.designPrinciples && planet.data.designPrinciples.length > 0 && (
      <>
        <DiamondDivider />
        <section class="realm-section reveal">
          <h2 class="section-title">Design Principles</h2>
          <DesignPrinciples principles={planet.data.designPrinciples} />
        </section>
      </>
    )}

    <DiamondDivider />

    <!-- ===== FOOTER ===== -->
    <footer class="realm-footer">
      <span>Crystata</span><br />
      Realm Codex — {planet.data.name}<br />
      <a href="/" style="color: var(--realm-mid); font-size: 0.75rem; text-decoration: none;">
        ← Return to Cosmos
      </a>
    </footer>
  </main>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Aether particles
    const container = document.getElementById('aetherParticles');
    if (container && container.children.length === 0) {
      for (let i = 0; i < 25; i++) {
        const p = document.createElement('div');
        p.className = 'aether-particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.animationDuration = (12 + Math.random() * 20) + 's';
        p.style.animationDelay = (Math.random() * 15) + 's';
        const size = (1 + Math.random() * 2) + 'px';
        p.style.width = size;
        p.style.height = size;
        container.appendChild(p);
      }
    }

    // Scroll reveal
    const reveals = document.querySelectorAll('.reveal');
    function checkReveal() {
      const windowHeight = window.innerHeight;
      reveals.forEach(el => {
        if (el.getBoundingClientRect().top < windowHeight - 80) {
          el.classList.add('visible');
        }
      });
    }
    window.addEventListener('scroll', checkReveal);
    setTimeout(checkReveal, 100);
  });
</script>

</body>
</html>
