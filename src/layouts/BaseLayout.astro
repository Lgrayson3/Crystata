---
import CosmosScene from '../components/CosmosScene';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
}

const { title = 'Crystata' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Crystata</title>
    <ClientRouter />
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <!-- Persistent WebGL canvas — survives client-side navigation -->
    <div transition:persist="cosmos-canvas" id="cosmos-container">
      <CosmosScene client:load />
    </div>

    <!-- Page content rendered by Astro routes -->
    <main id="content-layer">
      <slot />
    </main>
  </body>
</html>
